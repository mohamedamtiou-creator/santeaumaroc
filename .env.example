# `sslmode=verify-full` (et NON `require`) : vérifie le certificat serveur ET le
# hostname (comportement actuel de node-postgres, mais explicite). `require` seul
# devient « chiffré sans vérif cert » à la prochaine majeure de pg → warning +
# sécurité plus faible. Neon/Vercel Postgres présentent des certs publics valides
# → verify-full marche sans CA custom.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=verify-full"
# Taille du pool node-postgres PAR PROCESS (adapter-pg, réglé dans lib/prisma.ts).
# Défaut 20 si absent. DERRIÈRE UN POOLER (Neon/PgBouncer, URL poolée) → mettre 5 :
# le pooler gère la concurrence, un gros pool local le re-sature. Le build plafonne
# déjà à 5/worker automatiquement (fix P2037). N'a AUCUN rapport avec les params
# d'URL `connection_limit`/`pgbouncer` (ignorés par le driver adapter).
DATABASE_POOL_MAX=5
SESSION_SECRET="generate-with-openssl-rand-base64-32"
RESEND_API_KEY="re_xxxx"
TWILIO_ACCOUNT_SID="ACxxx"
TWILIO_AUTH_TOKEN="xxx"
TWILIO_PHONE_NUMBER="+212xxxxxxxxx"
NEXT_PUBLIC_APP_URL="https://santeaumaroc.ma"

# Profils sociaux officiels — alimentent le champ `sameAs` du JSON-LD Organization
# (consolide l'entité SantéauMaroc pour Google/knowledge graph → autorité off-page).
# Laisser vide tant que le profil n'existe pas : un champ vide est ignoré (pas de faux lien).
NEXT_PUBLIC_FACEBOOK_URL=""
NEXT_PUBLIC_INSTAGRAM_URL=""
NEXT_PUBLIC_LINKEDIN_URL=""
NEXT_PUBLIC_X_URL=""
NEXT_PUBLIC_YOUTUBE_URL=""
NEXT_PUBLIC_WIKIDATA_URL=""
